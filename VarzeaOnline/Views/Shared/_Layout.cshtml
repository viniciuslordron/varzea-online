<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - VarzeaOnline</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-controller"></i> VarzeaOnline
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="bi bi-house-fill"></i> Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Campeonato")">
                            <i class="bi bi-trophy-fill"></i> Campeonatos
                        </a>
                    </li>
                    @if (Request.IsAuthenticated)
                    {
                        <li class="nav-item ms-2">
                            <span class="nav-link" style="color: var(--ea-green); font-weight: 600;">
                                <i class="bi bi-person-fill"></i> @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="ea-btn ea-btn-red ea-btn-sm" href="@Url.Action("Logout", "Usuario")">
                                <i class="bi bi-box-arrow-right"></i> Sair
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-2">
                            <a class="ea-btn ea-btn-ghost ea-btn-sm" href="@Url.Action("Login", "Usuario")">
                                <i class="bi bi-box-arrow-in-right"></i> Entrar
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="ea-btn ea-btn-green ea-btn-sm" href="@Url.Action("Cadastro", "Usuario")">
                                <i class="bi bi-person-plus-fill"></i> Criar Conta
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <footer>
            <p>&copy; @DateTime.Now.Year VarzeaOnline &mdash; Campeonatos FIFA</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
