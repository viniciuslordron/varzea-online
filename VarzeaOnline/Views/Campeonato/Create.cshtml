@model VarzeaOnline.Models.Campeonato

@{
    ViewBag.Title = "Novo Campeonato";
}

<h2 class="page-title"><i class="bi bi-plus-circle-fill" style="color: var(--green);"></i> Novo Campeonato</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="ea-card fade-up">
        <div class="ea-card-header">
            <i class="bi bi-gear-fill"></i> Configurar Campeonato
        </div>
        <div class="ea-card-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">
                <div class="col-md-12">
                    <!-- NOME -->
                    <div class="ea-form-group">
                        <label class="ea-label">Nome do Campeonato</label>
                        @Html.TextBoxFor(model => model.Nome, new { @class = "ea-input", placeholder = "Ex: Copa FIFA 2026" })
                        @Html.ValidationMessageFor(model => model.Nome, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <!-- TIPO -->
                    <div class="ea-form-group">
                        <label class="ea-label">Formato</label>
                        @Html.DropDownList("TipoCampeonato", null, "Selecione o formato", new { @class = "ea-input ea-select", id = "ddlTipo" })
                        @Html.ValidationMessageFor(model => model.TipoCampeonato, "", new { @class = "text-danger" })
                        <div class="ea-form-hint" id="descricaoTipo"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <!-- QUANTIDADE -->
                    <div class="ea-form-group">
                        <label class="ea-label">Quantidade de Jogadores</label>
                        @Html.DropDownList("QuantidadeJogadores", (SelectList)ViewBag.QuantidadeOpcoes, "Selecione", new { @class = "ea-input ea-select" })
                        @Html.ValidationMessageFor(model => model.QuantidadeJogadores, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div style="margin-top: 12px;">
                <button type="submit" class="ea-btn ea-btn-green ea-btn-lg">
                    <i class="bi bi-check-circle-fill"></i> Criar Campeonato
                </button>
            </div>
        </div>
    </div>
}

<div style="margin-top: 1rem;">
    <a href="@Url.Action("Index")" class="ea-btn ea-btn-ghost">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            $('#ddlTipo').change(function () {
                var tipo = $(this).val();
                var desc = '';
                switch (tipo) {
                    case 'Pontos Corridos':
                        desc = 'Todos jogam contra todos. Quem fizer mais pontos vence! (3 pts vitoria, 1 empate)';
                        break;
                    case 'Mata-Mata':
                        desc = 'Eliminatoria direta. Perdeu, esta fora!';
                        break;
                    case 'Fase de Grupos + Mata-Mata':
                        desc = 'Fase de grupos classificatoria + eliminatorias ate a final.';
                        break;
                }
                $('#descricaoTipo').text(desc);
            });
        });
    </script>
}
