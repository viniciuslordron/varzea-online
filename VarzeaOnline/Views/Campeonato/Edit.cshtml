@model VarzeaOnline.Models.Campeonato

@{
    ViewBag.Title = "Editar Campeonato";
}

<h2 class="page-title"><i class="bi bi-pencil-fill" style="color: var(--gold);"></i> Editar Campeonato</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.IdCampeonato)

    <div class="ea-card fade-up">
        <div class="ea-card-header">
            <i class="bi bi-gear-fill"></i> Configuracoes
        </div>
        <div class="ea-card-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">
                <div class="col-md-12">
                    <div class="ea-form-group">
                        <label class="ea-label">Nome do Campeonato</label>
                        @Html.TextBoxFor(model => model.Nome, new { @class = "ea-input" })
                        @Html.ValidationMessageFor(model => model.Nome, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="ea-form-group">
                        <label class="ea-label">Formato</label>
                        @Html.DropDownList("TipoCampeonato", null, "Selecione o formato", new { @class = "ea-input ea-select" })
                        @Html.ValidationMessageFor(model => model.TipoCampeonato, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ea-form-group">
                        <label class="ea-label">Quantidade de Jogadores</label>
                        @Html.DropDownList("QuantidadeJogadores", (SelectList)ViewBag.QuantidadeOpcoes, "Selecione", new { @class = "ea-input ea-select" })
                        @Html.ValidationMessageFor(model => model.QuantidadeJogadores, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div style="margin-top: 12px; display: flex; gap: 12px;">
                <button type="submit" class="ea-btn ea-btn-green ea-btn-lg">
                    <i class="bi bi-check-circle-fill"></i> Salvar
                </button>
                <a href="@Url.Action("Index")" class="ea-btn ea-btn-ghost ea-btn-lg">
                    <i class="bi bi-x-lg"></i> Cancelar
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}