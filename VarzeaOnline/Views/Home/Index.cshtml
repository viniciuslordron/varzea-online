@{
    ViewBag.Title = "Inicio";
}

<div class="hero fade-up">
    <h1 class="hero-title">VarzeaOnline</h1>
    <p class="hero-sub">Organize seus campeonatos de FIFA como um profissional</p>
    <a href="@Url.Action("Create", "Campeonato")" class="ea-btn ea-btn-green ea-btn-lg">
        <i class="bi bi-plus-circle-fill"></i> Criar Campeonato
    </a>
</div>

<div class="row g-4" style="margin-bottom: 3rem;">
    <div class="col-md-4 fade-up fade-up-delay-1">
        <div class="feat-card">
            <span class="feat-icon">&#9917;</span>
            <h3>Crie Campeonatos</h3>
            <p>Pontos corridos, mata-mata ou fase de grupos. Escolha o formato ideal para sua galera.</p>
        </div>
    </div>
    <div class="col-md-4 fade-up fade-up-delay-2">
        <div class="feat-card">
            <span class="feat-icon">&#127942;</span>
            <h3>Times Reais</h3>
            <p>Mais de 50 times de ligas como Premier League, La Liga, Serie A e Brasileirao.</p>
        </div>
    </div>
    <div class="col-md-4 fade-up fade-up-delay-3">
        <div class="feat-card">
            <span class="feat-icon">&#128202;</span>
            <h3>Classificacao</h3>
            <p>Tabela automatica com pontos, vitorias, saldo de gols e muito mais.</p>
        </div>
    </div>
</div>
